Private Sub CollectCalledProcedureNames( _
    ByVal vbProj As Object, _
    ByVal calledNames As Object)

    Dim vbComp As Object
    Dim codeMod As Object
    Dim i As Long
    Dim lineText As String
    Dim calledName As String

    For Each vbComp In vbProj.VBComponents

        Set codeMod = vbComp.CodeModule

        For i = 1 To codeMod.CountOfLines

            lineText = Trim(codeMod.lines(i, 1))

            If lineText <> "" And Left$(lineText, 1) <> "'" Then

                calledName = ExtractCallName(lineText)

                If calledName <> "" Then
                    calledName = NormalizeProcedureName(calledName)

                    If Not calledNames.Exists(calledName) Then
                        calledNames.Add calledName, True
                    End If
                End If

            End If

        Next i

    Next vbComp

End Sub

Private Function IsUnusedCandidate( _
    ByVal signature As String, _
    ByVal procName As String, _
    ByVal calledNames As Object) As Boolean

    Dim normalizedName As String

    If Not IsPrivateProcedure(signature) Then
        IsUnusedCandidate = False
        Exit Function
    End If

    If IsEventProcedureName(procName) Then
        IsUnusedCandidate = False
        Exit Function
    End If

    normalizedName = NormalizeProcedureName(procName)

    If calledNames.Exists(normalizedName) Then
        IsUnusedCandidate = False
    Else
        IsUnusedCandidate = True
    End If

End Function

Private Function IsPrivateProcedure(ByVal signature As String) As Boolean

    Dim t As String
    t = LCase$(Trim(signature))

    IsPrivateProcedure = _
        Left$(t, 11) = "private sub" Or _
        Left$(t, 16) = "private function" Or _
        Left$(t, 16) = "private property"

End Function

Private Function NormalizeProcedureName(ByVal procName As String) As String

    Dim p As Long

    procName = Trim(procName)

    If InStr(procName, ".") > 0 Then
        procName = Mid$(procName, InStrRev(procName, ".") + 1)
    End If

    p = InStr(procName, "(")
    If p > 0 Then procName = Left$(procName, p - 1)

    NormalizeProcedureName = LCase$(Trim(procName))

End Function

Private Function IsEventProcedureName(ByVal procName As String) As Boolean

    Dim t As String
    t = LCase$(procName)

    IsEventProcedureName = _
        t = "workbook_open" Or _
        t = "workbook_beforeclose" Or _
        t = "workbook_beforesave" Or _
        t = "workbook_sheetchange" Or _
        t = "worksheet_change" Or _
        t = "worksheet_selectionchange" Or _
        t = "worksheet_activate" Or _
        t = "worksheet_deactivate" Or _
        t = "userform_initialize" Or _
        t = "userform_activate" Or _
        t = "userform_terminate" Or _
        t = "class_initialize" Or _
        t = "class_terminate" Or _
        Right$(t, 6) = "_click" Or _
        Right$(t, 7) = "_change" Or _
        Right$(t, 6) = "_close" Or _
        Right$(t, 9) = "_keydown" Or _
        Right$(t, 7) = "_keyup" Or _
        Right$(t, 10) = "_keypress" Or _
        Right$(t, 10) = "_dblclick"

End Function

