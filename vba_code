Private Function AddSummaryRow( _
    ByVal ws As Worksheet, _
    ByVal row As Long, _
    ByVal itemName As String, _
    ByVal countValue As Long, _
    ByVal targetSheetName As String) As Long

    ws.Cells(row, 1).Value = itemName
    ws.Cells(row, 2).Value = countValue
    ws.Cells(row, 3).Value = targetSheetName

    AddSummaryRow = row + 1

End Function

Private Function CountDataRows( _
    ByVal wb As Workbook, _
    ByVal sheetName As String) As Long

    Dim ws As Worksheet
    Dim lastRow As Long

    On Error Resume Next
    Set ws = wb.Worksheets(sheetName)
    On Error GoTo 0

    If ws Is Nothing Then
        CountDataRows = 0
        Exit Function
    End If

    lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).row

    If lastRow <= 1 Then
        CountDataRows = 0
    Else
        CountDataRows = lastRow - 1
    End If

End Function

