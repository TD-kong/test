Private Function MakeStableProcessId( _
    ByVal moduleName As String, _
    ByVal procName As String) As String

    MakeStableProcessId = CleanIdText(moduleName) & "_" & CleanIdText(procName)

End Function

Private Function CleanIdText(ByVal text As String) As String

    Dim result As String
    Dim i As Long
    Dim ch As String

    For i = 1 To Len(text)

        ch = Mid$(text, i, 1)

        If ch Like "[A-Za-z0-9_]" Then
            result = result & ch
        Else
            result = result & "_"
        End If

    Next i

    CleanIdText = result

End Function

