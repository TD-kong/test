Option Explicit


'==================================================
' 選択したファイルのVBAコードから詳細設計書を生成する
' 出力先: 設計書生成マクロの "詳細設計書" シート
'==================================================

Public Sub GenerateVbaDetailDesignDocumentFromFile()

    Dim filePath As Variant
    Dim targetWb As Workbook
    Dim outputWb As Workbook
    Dim vbProj As Object
    Dim vbComp As Object
    Dim codeMod As Object
    Dim ws As Worksheet
    Dim row As Long

    Call BackupPreviousDesignSheet(ThisWorkbook) 'メイン処理の最初に追加

    filePath = Application.GetOpenFilename( _
        FileFilter:="Excel Macro Files (*.xlsm;*.xlsb;*.xlam),*.xlsm;*.xlsb;*.xlam", _
        title:="仕様書を作成するマクロファイルを選択してください")

    If filePath = False Then Exit Sub

    Application.ScreenUpdating = False

    Set outputWb = ThisWorkbook

    Set targetWb = Workbooks.Open( _
        Filename:=CStr(filePath), _
        ReadOnly:=True)

    Set vbProj = targetWb.VBProject
    Set ws = PrepareDesignSheet(outputWb)

    row = 2

    For Each vbComp In vbProj.VBComponents

        Set codeMod = vbComp.CodeModule

        If codeMod.CountOfLines > 0 Then
            row = OutputComponentInfo(ws, row, vbComp, codeMod)
        End If

    Next vbComp

    targetWb.Close SaveChanges:=False

    ws.Columns.AutoFit
    Application.ScreenUpdating = True

    MsgBox "選択したマクロファイルの詳細設計書を生成しました。", vbInformation
    
    Call OutputVariableList(vbProj, ThisWorkbook)
    Call OutputCallRelationList(vbProj, ThisWorkbook)
    Call OutputSheetIoList(vbProj, ThisWorkbook)
    Call OutputUserFormControlList(vbProj, ThisWorkbook)
    Call OutputProcessFlowList(vbProj, ThisWorkbook)
    Call OutputSummarySheet(ThisWorkbook)
    Call FormatDesignWorkbook(ThisWorkbook)
    'Call ApplyStableProcessIds(ThisWorkbook)
    'Call OutputProcedureCodeList(vbProj, ThisWorkbook)
    Call OutputProcedureCodeList(vbProj, ThisWorkbook)
    Call AddCodeLinksToDesignSheet(ThisWorkbook)
    
    'メイン処理の最後に入れる
    Call OutputCommentQualityList(vbProj, ThisWorkbook)
    Call OutputUnusedProcedureCandidates(vbProj, ThisWorkbook)
    Call OutputConstEnumTypeList(vbProj, ThisWorkbook)
    Call OutputNamingRuleCheck(vbProj, ThisWorkbook)
    Call OutputDiffReport(ThisWorkbook)
    Call ExportDesignWorkbookToCustomHtml(ThisWorkbook)
End Sub

'==================================================
' 出力シート作成
'==================================================

Private Function PrepareDesignSheet(ByVal wb As Workbook) As Worksheet

    Dim ws As Worksheet

    On Error Resume Next
    Set ws = wb.Worksheets("詳細設計書")
    On Error GoTo 0

    If ws Is Nothing Then
        Set ws = wb.Worksheets.Add
        ws.Name = "詳細設計書"
    Else
        ws.Cells.Clear
    End If

    With ws
        .Range("A1").Value = "処理ID"
        .Range("B1").Value = "モジュール種別"
        .Range("C1").Value = "モジュール名"
        .Range("D1").Value = "プロシージャ種別"
        .Range("E1").Value = "プロシージャ名"
        .Range("F1").Value = "開始行"
        .Range("G1").Value = "終了行"
        .Range("H1").Value = "引数"
        .Range("I1").Value = "戻り値"
        .Range("J1").Value = "概要"
        .Range("K1").Value = "入力"
        .Range("L1").Value = "出力"
        .Range("M1").Value = "使用テーブル"
        .Range("N1").Value = "更新対象"
        .Range("O1").Value = "画面項目"
        .Range("P1").Value = "エラー処理"
        .Range("Q1").Value = "処理内容"
        .Range("R1").Value = "呼び出し関数候補"

        .Rows(1).Font.Bold = True
        .Rows(1).Interior.Color = RGB(220, 230, 241)
    End With

    Set PrepareDesignSheet = ws

End Function

'==================================================
' モジュール単位で情報出力
'==================================================

Private Function OutputComponentInfo( _
    ByVal ws As Worksheet, _
    ByVal startRow As Long, _
    ByVal vbComp As VBIDE.VBComponent, _
    ByVal codeMod As VBIDE.CodeModule) As Long

    Dim lineNo As Long
    Dim procName As String
    Dim procKind As VBIDE.vbext_ProcKind
    Dim procStart As Long
    Dim procLines As Long
    Dim procEnd As Long
    Dim signature As String
    Dim row As Long

    Dim specSummary As String
    Dim specInput As String
    Dim specOutput As String
    Dim specTables As String
    Dim specUpdateTargets As String
    Dim specScreenItems As String
    Dim specErrorHandling As String

    row = startRow
    lineNo = 1

    Do While lineNo <= codeMod.CountOfLines

        procName = GetProcedureName(codeMod, lineNo, procKind)

        If procName <> "" Then

            procStart = codeMod.ProcStartLine(procName, procKind)
            procLines = codeMod.ProcCountLines(procName, procKind)
            procEnd = procStart + procLines - 1

            signature = GetProcedureSignature(codeMod, procStart, procEnd)

            specSummary = GetSpecCommentValue(codeMod, procStart, "概要")
            specInput = GetSpecCommentValue(codeMod, procStart, "入力")
            specOutput = GetSpecCommentValue(codeMod, procStart, "出力")
            specTables = GetSpecCommentValue(codeMod, procStart, "使用テーブル")
            specUpdateTargets = GetSpecCommentValue(codeMod, procStart, "更新対象")
            specScreenItems = GetSpecCommentValue(codeMod, procStart, "画面項目")
            specErrorHandling = GetSpecCommentValue(codeMod, procStart, "エラー処理")
            
            ws.Cells(row, 1).Value = MakeStableProcessId(vbComp.Name, procName)
            ws.Cells(row, 2).Value = GetComponentTypeName(vbComp.Type)
            ws.Cells(row, 3).Value = vbComp.Name
            ws.Cells(row, 4).Value = GetProcedureKindName(signature)
            ws.Cells(row, 5).Value = procName
            ws.Cells(row, 6).Value = procStart
            ws.Cells(row, 7).Value = procEnd
            ws.Cells(row, 8).Value = ExtractArguments(signature)
            ws.Cells(row, 9).Value = ExtractReturnType(signature)
            
            ws.Cells(row, 10).Value = PreferSpecValue(specSummary, ExtractSummaryComment(codeMod, procStart))
            ws.Cells(row, 11).Value = PreferSpecValue(specInput, ExtractInputs(codeMod, procStart, procEnd, signature))
            ws.Cells(row, 12).Value = PreferSpecValue(specOutput, ExtractOutputs(codeMod, procStart, procEnd, signature))
            ws.Cells(row, 13).Value = PreferSpecValue(specTables, ExtractTables(codeMod, procStart, procEnd))
            ws.Cells(row, 14).Value = PreferSpecValue(specUpdateTargets, ExtractUpdateTargets(codeMod, procStart, procEnd))
            ws.Cells(row, 15).Value = PreferSpecValue(specScreenItems, ExtractScreenItems(codeMod, procStart, procEnd))
            ws.Cells(row, 16).Value = PreferSpecValue(specErrorHandling, ExtractErrorHandling(codeMod, procStart, procEnd))
            
            ws.Cells(row, 17).Value = ExtractProcessSummary(codeMod, procStart, procEnd)
            ws.Cells(row, 18).Value = ExtractCallCandidates(codeMod, procStart, procEnd)

            row = row + 1
            lineNo = procEnd + 1

        Else
            lineNo = lineNo + 1
        End If

    Loop

    OutputComponentInfo = row

End Function

'==================================================
' プロシージャ名取得
'==================================================

Private Function GetProcedureName( _
    ByVal codeMod As VBIDE.CodeModule, _
    ByVal lineNo As Long, _
    ByRef procKind As VBIDE.vbext_ProcKind) As String

    On Error Resume Next

    procKind = vbext_pk_Proc
    GetProcedureName = codeMod.ProcOfLine(lineNo, procKind)

    On Error GoTo 0

End Function

'==================================================
' 宣言行取得
'==================================================

Private Function GetProcedureSignature( _
    ByVal codeMod As VBIDE.CodeModule, _
    ByVal procStart As Long, _
    ByVal procEnd As Long) As String

    Dim i As Long
    Dim lineText As String
    Dim sig As String

    For i = procStart To procEnd

        lineText = Trim(codeMod.lines(i, 1))

        If IsProcedureDeclaration(lineText) Then
            sig = lineText

            Do While Right(sig, 1) = "_"
                i = i + 1
                sig = Left(sig, Len(sig) - 1) & " " & Trim(codeMod.lines(i, 1))
            Loop

            GetProcedureSignature = sig
            Exit Function
        End If

    Next i

End Function

Private Function IsProcedureDeclaration(ByVal lineText As String) As Boolean

    Dim t As String
    t = LCase$(Trim(lineText))

    IsProcedureDeclaration = _
        t Like "sub *" Or _
        t Like "function *" Or _
        t Like "property get *" Or _
        t Like "property let *" Or _
        t Like "property set *" Or _
        t Like "public sub *" Or _
        t Like "public function *" Or _
        t Like "private sub *" Or _
        t Like "private function *" Or _
        t Like "friend sub *" Or _
        t Like "friend function *" Or _
        t Like "public property *" Or _
        t Like "private property *"

End Function

'==================================================
' 種別変換
'==================================================

Private Function GetComponentTypeName(ByVal compType As VBIDE.vbext_ComponentType) As String

    Select Case compType
        Case vbext_ct_StdModule
            GetComponentTypeName = "標準モジュール"
        Case vbext_ct_ClassModule
            GetComponentTypeName = "クラスモジュール"
        Case vbext_ct_MSForm
            GetComponentTypeName = "ユーザーフォーム"
        Case vbext_ct_Document
            GetComponentTypeName = "シート/ブックモジュール"
        Case Else
            GetComponentTypeName = "その他"
    End Select

End Function

Private Function GetProcedureKindName(ByVal signature As String) As String

    Dim t As String
    t = LCase$(signature)

    If InStr(t, "function ") > 0 Then
        GetProcedureKindName = "Function"
    ElseIf InStr(t, "sub ") > 0 Then
        GetProcedureKindName = "Sub"
    ElseIf InStr(t, "property get ") > 0 Then
        GetProcedureKindName = "Property Get"
    ElseIf InStr(t, "property let ") > 0 Then
        GetProcedureKindName = "Property Let"
    ElseIf InStr(t, "property set ") > 0 Then
        GetProcedureKindName = "Property Set"
    Else
        GetProcedureKindName = "不明"
    End If

End Function

'==================================================
' 引数抽出
'==================================================

Private Function ExtractArguments(ByVal signature As String) As String

    Dim p1 As Long
    Dim p2 As Long

    p1 = InStr(signature, "(")
    p2 = InStrRev(signature, ")")

    If p1 > 0 And p2 > p1 Then
        ExtractArguments = Mid$(signature, p1 + 1, p2 - p1 - 1)
    Else
        ExtractArguments = ""
    End If

End Function

'==================================================
' 戻り値抽出
'==================================================

Private Function ExtractReturnType(ByVal signature As String) As String

    Dim p As Long
    Dim t As String

    t = Trim(signature)
    p = InStrRev(LCase$(t), " as ")

    If InStr(LCase$(t), "function ") > 0 And p > 0 Then
        ExtractReturnType = Mid$(t, p + 4)
    Else
        ExtractReturnType = ""
    End If

End Function

'==================================================
' 直前コメントを概要として取得
'==================================================

Private Function ExtractSummaryComment( _
    ByVal codeMod As VBIDE.CodeModule, _
    ByVal procStart As Long) As String

    Dim i As Long
    Dim lineText As String
    Dim result As String

    For i = procStart - 1 To 1 Step -1

        lineText = Trim(codeMod.lines(i, 1))

        If lineText = "" Then
            Exit For
        End If

        If Left$(lineText, 1) = "'" Then
            result = Mid$(lineText, 2) & vbLf & result
        Else
            Exit For
        End If

    Next i

    ExtractSummaryComment = Trim(result)

End Function

'==================================================
' 処理内容の簡易要約
'==================================================

Private Function ExtractProcessSummary( _
    ByVal codeMod As VBIDE.CodeModule, _
    ByVal procStart As Long, _
    ByVal procEnd As Long) As String

    Dim i As Long
    Dim lineText As String
    Dim result As String

    For i = procStart To procEnd

        lineText = Trim(codeMod.lines(i, 1))

        If lineText <> "" Then

            If Left$(lineText, 1) <> "'" Then

                Select Case True
                    Case LCase$(lineText) Like "if * then*"
                        result = result & "条件分岐: " & lineText & vbLf

                    Case LCase$(lineText) Like "for *"
                        result = result & "繰り返し処理: " & lineText & vbLf

                    Case LCase$(lineText) Like "do *"
                        result = result & "繰り返し処理: " & lineText & vbLf

                    Case LCase$(lineText) Like "select case *"
                        result = result & "条件分岐: " & lineText & vbLf

                    Case InStr(LCase$(lineText), "open ") > 0
                        result = result & "ファイル操作: " & lineText & vbLf

                    Case InStr(LCase$(lineText), "sql") > 0
                        result = result & "SQL関連処理: " & lineText & vbLf
                End Select

            End If

        End If

    Next i

    ExtractProcessSummary = Trim(result)

End Function

'==================================================
' 呼び出し関数候補の簡易抽出
'==================================================

Private Function ExtractCallCandidates( _
    ByVal codeMod As VBIDE.CodeModule, _
    ByVal procStart As Long, _
    ByVal procEnd As Long) As String

    Dim i As Long
    Dim lineText As String
    Dim result As String

    For i = procStart To procEnd

        lineText = Trim(codeMod.lines(i, 1))

        If lineText <> "" Then
            If Left$(lineText, 1) <> "'" Then

                If LCase$(Left$(lineText, 5)) = "call " Then
                    result = result & Mid$(lineText, 6) & vbLf
                ElseIf InStr(lineText, "(") > 0 And InStr(lineText, "=") = 0 Then
                    If Not IsProcedureDeclaration(lineText) Then
                        result = result & lineText & vbLf
                    End If
                End If

            End If
        End If

    Next i

    ExtractCallCandidates = Trim(result)

End Function

Private Function ExtractInputs( _
    ByVal codeMod As Object, _
    ByVal procStart As Long, _
    ByVal procEnd As Long, _
    ByVal signature As String) As String

    Dim result As String
    Dim args As String

    args = ExtractArguments(signature)

    If args <> "" Then
        result = "引数: " & args & vbLf
    End If

    result = result & ExtractLinesByKeywords(codeMod, procStart, procEnd, _
        Array("inputbox", "getopenfilename", "cells(", "range(", ".value", "worksheets(", "sheets("))

    ExtractInputs = Trim(result)

End Function

Private Function ExtractOutputs( _
    ByVal codeMod As Object, _
    ByVal procStart As Long, _
    ByVal procEnd As Long, _
    ByVal signature As String) As String

    Dim result As String

    If ExtractReturnType(signature) <> "" Then
        result = "戻り値: " & ExtractReturnType(signature) & vbLf
    End If

    result = result & ExtractLinesByKeywords(codeMod, procStart, procEnd, _
        Array("msgbox", "print #", "debug.print", "saveas", "exportasfixedformat", ".value =", ".copy"))

    ExtractOutputs = Trim(result)

End Function

Private Function ExtractTables( _
    ByVal codeMod As Object, _
    ByVal procStart As Long, _
    ByVal procEnd As Long) As String

    Dim i As Long
    Dim lineText As String
    Dim sqlText As String
    Dim result As String

    For i = procStart To procEnd

        lineText = Trim(codeMod.lines(i, 1))

        If lineText <> "" Then
            If Left$(lineText, 1) <> "'" Then

                If LooksLikeSqlLine(lineText) Then
                    sqlText = sqlText & " " & ExtractStringLiteralText(lineText)
                    sqlText = sqlText & " " & lineText
                End If

            End If
        End If

    Next i

    result = ExtractTableNamesFromSql(sqlText)

    ExtractTables = result

End Function

Private Function ExtractUpdateTargets( _
    ByVal codeMod As Object, _
    ByVal procStart As Long, _
    ByVal procEnd As Long) As String

    ExtractUpdateTargets = ExtractLinesByKeywords(codeMod, procStart, procEnd, _
        Array(".value =", ".formula =", ".clear", ".delete", ".insert", ".copy", " update ", " insert into ", " delete from "))

End Function

Private Function ExtractScreenItems( _
    ByVal codeMod As Object, _
    ByVal procStart As Long, _
    ByVal procEnd As Long) As String

    ExtractScreenItems = ExtractLinesByKeywords(codeMod, procStart, procEnd, _
        Array("userform", "textbox", "combobox", "listbox", "checkbox", "optionbutton", "commandbutton", ".caption", ".text"))

End Function

Private Function ExtractErrorHandling( _
    ByVal codeMod As Object, _
    ByVal procStart As Long, _
    ByVal procEnd As Long) As String

    ExtractErrorHandling = ExtractLinesByKeywords(codeMod, procStart, procEnd, _
        Array("on error", "err.", "errorhandler", "resume", "raise"))

End Function

Private Function ExtractLinesByKeywords( _
    ByVal codeMod As Object, _
    ByVal procStart As Long, _
    ByVal procEnd As Long, _
    ByVal keywords As Variant) As String

    Dim i As Long
    Dim j As Long
    Dim lineText As String
    Dim lowerLine As String
    Dim result As String

    For i = procStart To procEnd

        lineText = Trim(codeMod.lines(i, 1))
        lowerLine = LCase$(lineText)

        If lineText <> "" Then
            If Left$(lineText, 1) <> "'" Then

                For j = LBound(keywords) To UBound(keywords)
                    If InStr(lowerLine, LCase$(CStr(keywords(j)))) > 0 Then
                        result = result & "L" & i & ": " & lineText & vbLf
                        Exit For
                    End If
                Next j

            End If
        End If

    Next i

    ExtractLinesByKeywords = Trim(result)

End Function


Private Function LooksLikeSqlLine(ByVal lineText As String) As Boolean

    Dim t As String
    t = LCase$(lineText)

    LooksLikeSqlLine = _
        InStr(t, "select ") > 0 Or _
        InStr(t, " from ") > 0 Or _
        InStr(t, " join ") > 0 Or _
        InStr(t, " update ") > 0 Or _
        InStr(t, "insert into ") > 0 Or _
        InStr(t, "delete from ") > 0

End Function

Private Function ExtractStringLiteralText(ByVal lineText As String) As String

    Dim i As Long
    Dim inString As Boolean
    Dim ch As String
    Dim result As String

    For i = 1 To Len(lineText)

        ch = Mid$(lineText, i, 1)

        If ch = """" Then
            inString = Not inString
        ElseIf inString Then
            result = result & ch
        End If

    Next i

    ExtractStringLiteralText = result

End Function

Private Function ExtractTableNamesFromSql(ByVal sqlText As String) As String

    Dim result As String

    sqlText = NormalizeSqlText(sqlText)

    result = AddTableNamesByPattern(result, sqlText, "\bfrom\s+([a-zA-Z0-9_\.\[\]`]+)")
    result = AddTableNamesByPattern(result, sqlText, "\bjoin\s+([a-zA-Z0-9_\.\[\]`]+)")
    result = AddTableNamesByPattern(result, sqlText, "\bupdate\s+([a-zA-Z0-9_\.\[\]`]+)")
    result = AddTableNamesByPattern(result, sqlText, "\binsert\s+into\s+([a-zA-Z0-9_\.\[\]`]+)")
    result = AddTableNamesByPattern(result, sqlText, "\bdelete\s+from\s+([a-zA-Z0-9_\.\[\]`]+)")

    ExtractTableNamesFromSql = Trim(result)

End Function

Private Function NormalizeSqlText(ByVal sqlText As String) As String

    sqlText = Replace(sqlText, vbCr, " ")
    sqlText = Replace(sqlText, vbLf, " ")
    sqlText = Replace(sqlText, vbTab, " ")
    sqlText = Replace(sqlText, """", " ")
    sqlText = Replace(sqlText, "'", " ")

    Do While InStr(sqlText, "  ") > 0
        sqlText = Replace(sqlText, "  ", " ")
    Loop

    NormalizeSqlText = " " & LCase$(Trim(sqlText)) & " "

End Function

Private Function AddTableNamesByPattern( _
    ByVal currentResult As String, _
    ByVal sqlText As String, _
    ByVal pattern As String) As String

    Dim reg As Object
    Dim matches As Object
    Dim match As Object
    Dim tableName As String
    Dim result As String

    result = currentResult

    Set reg = CreateObject("VBScript.RegExp")

    With reg
        .Global = True
        .IgnoreCase = True
        .pattern = pattern
    End With

    If reg.Test(sqlText) Then

        Set matches = reg.Execute(sqlText)

        For Each match In matches

            tableName = match.SubMatches(0)
            tableName = CleanTableName(tableName)

            If tableName <> "" Then
                If Not ContainsLine(result, tableName) Then
                    result = result & tableName & vbLf
                End If
            End If

        Next match

    End If

    AddTableNamesByPattern = result

End Function

Private Function CleanTableName(ByVal tableName As String) As String

    tableName = Trim(tableName)

    tableName = Replace(tableName, "[", "")
    tableName = Replace(tableName, "]", "")
    tableName = Replace(tableName, "`", "")
    tableName = Replace(tableName, ";", "")
    tableName = Replace(tableName, ",", "")

    If InStr(tableName, ".") > 0 Then
        ' dbo.TableName のような形式はそのまま残す
        CleanTableName = tableName
    Else
        CleanTableName = tableName
    End If

End Function

Private Function ContainsLine( _
    ByVal text As String, _
    ByVal target As String) As Boolean

    Dim lines As Variant
    Dim i As Long

    If Trim(text) = "" Then
        ContainsLine = False
        Exit Function
    End If

    lines = Split(text, vbLf)

    For i = LBound(lines) To UBound(lines)
        If LCase$(Trim(lines(i))) = LCase$(Trim(target)) Then
            ContainsLine = True
            Exit Function
        End If
    Next i

    ContainsLine = False

End Function

Private Function PreferSpecValue( _
    ByVal specValue As String, _
    ByVal autoValue As String) As String

    If Trim(specValue) <> "" Then
        PreferSpecValue = specValue
    Else
        PreferSpecValue = autoValue
    End If

End Function

Private Function GetSpecCommentValue( _
    ByVal codeMod As Object, _
    ByVal procStart As Long, _
    ByVal itemName As String) As String

    Dim comments As Collection
    Dim lineText As Variant
    Dim result As String

    Set comments = GetProcedureHeaderComments(codeMod, procStart)

    For Each lineText In comments
        result = AppendSpecCommentLine(result, CStr(lineText), itemName)
    Next lineText

    GetSpecCommentValue = Trim(result)

End Function

Private Function GetProcedureHeaderComments( _
    ByVal codeMod As Object, _
    ByVal procStart As Long) As Collection

    Dim comments As Collection
    Dim tmp As Collection
    Dim i As Long
    Dim lineText As String

    Set comments = New Collection
    Set tmp = New Collection

    For i = procStart - 1 To 1 Step -1

        lineText = Trim(codeMod.lines(i, 1))

        If lineText = "" Then
            Exit For
        End If

        If Left$(lineText, 1) = "'" Then
            tmp.Add Mid$(lineText, 2)
        Else
            Exit For
        End If

    Next i

    For i = tmp.Count To 1 Step -1
        comments.Add Trim(CStr(tmp(i)))
    Next i

    Set GetProcedureHeaderComments = comments

End Function

Private Function AppendSpecCommentLine( _
    ByVal currentValue As String, _
    ByVal commentLine As String, _
    ByVal itemName As String) As String

    Dim p As Long
    Dim key As String
    Dim valueText As String

    commentLine = Trim(commentLine)

    p = InStr(commentLine, ":")

    If p = 0 Then
        p = InStr(commentLine, "：")
    End If

    If p = 0 Then
        AppendSpecCommentLine = currentValue
        Exit Function
    End If

    key = Trim(Left$(commentLine, p - 1))
    valueText = Trim(Mid$(commentLine, p + 1))

    If LCase$(key) = LCase$(itemName) Then
        If Trim(currentValue) <> "" Then
            AppendSpecCommentLine = currentValue & vbLf & valueText
        Else
            AppendSpecCommentLine = valueText
        End If
    Else
        AppendSpecCommentLine = currentValue
    End If

End Function

Private Function PrepareOutputSheet(ByVal wb As Workbook, ByVal sheetName As String) As Worksheet

    Dim ws As Worksheet

    On Error Resume Next
    Set ws = wb.Worksheets(sheetName)
    On Error GoTo 0

    If ws Is Nothing Then
        Set ws = wb.Worksheets.Add(After:=wb.Worksheets(wb.Worksheets.Count))
        ws.Name = sheetName
    Else
        ws.Cells.Clear
    End If

    Set PrepareOutputSheet = ws

End Function

Private Sub OutputVariableList(ByVal vbProj As Object, ByVal wb As Workbook)

    Dim ws As Worksheet
    Dim vbComp As Object
    Dim codeMod As Object
    Dim i As Long
    Dim row As Long
    Dim lineText As String
    Dim procName As String
    Dim procKind As Long

    Set ws = PrepareOutputSheet(wb, "変数一覧")

    ws.Range("A1:G1").Value = Array("モジュール名", "プロシージャ名", "スコープ", "変数名", "型", "初期値", "行番号")
    row = 2

    For Each vbComp In vbProj.VBComponents
        Set codeMod = vbComp.CodeModule

        For i = 1 To codeMod.CountOfLines
            lineText = Trim(codeMod.lines(i, 1))

            If IsVariableDeclarationLine(lineText) Then
                procName = ""
                On Error Resume Next
                procName = codeMod.ProcOfLine(i, procKind)
                On Error GoTo 0

                ws.Cells(row, 1).Value = vbComp.Name
                ws.Cells(row, 2).Value = procName
                ws.Cells(row, 3).Value = GetVariableScope(lineText)
                ws.Cells(row, 4).Value = GetVariableName(lineText)
                ws.Cells(row, 5).Value = GetVariableType(lineText)
