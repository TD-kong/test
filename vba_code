Private Function ExtractCallName(ByVal lineText As String) As String

    Dim t As String
    Dim p As Long

    t = Trim(lineText)

    If LCase$(Left$(t, 5)) = "call " Then
        t = Trim(Mid$(t, 6))
        p = InStr(t, "(")
        If p > 0 Then t = Left$(t, p - 1)
        ExtractCallName = Trim(t)
        Exit Function
    End If

    If InStr(t, "(") > 0 And InStr(t, "=") = 0 Then
        If Not IsProcedureDeclaration(t) Then
            ExtractCallName = Trim(Left$(t, InStr(t, "(") - 1))
        End If
    End If

End Function

