                If IsConstDeclarationLine(lineText) Then
                    ws.Cells(row, 1).Value = vbComp.Name
                    ws.Cells(row, 2).Value = "Const"
                    ws.Cells(row, 3).Value = ""
                    ws.Cells(row, 4).Value = GetConstName(lineText)
                    ws.Cells(row, 5).Value = GetVariableType(lineText)
                    ws.Cells(row, 6).Value = GetVariableInitialValue(lineText)
                    ws.Cells(row, 7).Value = lineText
                    ws.Cells(row, 8).Value = i
                    row = row + 1

                ElseIf IsEnumStartLine(lineText) Then
                    blockKind = "Enum"
                    blockName = GetBlockName(lineText, "Enum")

                    ws.Cells(row, 1).Value = vbComp.Name
                    ws.Cells(row, 2).Value = "Enum"
                    ws.Cells(row, 3).Value = blockName
                    ws.Cells(row, 4).Value = ""
                    ws.Cells(row, 7).Value = lineText
                    ws.Cells(row, 8).Value = i
                    row = row + 1

                ElseIf IsTypeStartLine(lineText) Then
                    blockKind = "Type"
                    blockName = GetBlockName(lineText, "Type")

                    ws.Cells(row, 1).Value = vbComp.Name
                    ws.Cells(row, 2).Value = "Type"
                    ws.Cells(row, 3).Value = blockName
                    ws.Cells(row, 4).Value = ""
                    ws.Cells(row, 7).Value = lineText
                    ws.Cells(row, 8).Value = i
                    row = row + 1

                ElseIf blockKind = "Enum" Then

                    If LCase$(lineText) = "end enum" Then
                        blockKind = ""
                        blockName = ""
                    Else
                        memberName = GetEnumMemberName(lineText)
                        memberValue = GetEnumMemberValue(lineText)

                        ws.Cells(row, 1).Value = vbComp.Name
                        ws.Cells(row, 2).Value = "EnumMember"
                        ws.Cells(row, 3).Value = blockName
                        ws.Cells(row, 4).Value = memberName
                        ws.Cells(row, 6).Value = memberValue
                        ws.Cells(row, 7).Value = lineText
                        ws.Cells(row, 8).Value = i
                        row = row + 1
                    End If

                ElseIf blockKind = "Type" Then

                    If LCase$(lineText) = "end type" Then
                        blockKind = ""
                        blockName = ""
                    Else
                        memberName = GetVariableName(lineText)
                        memberType = GetVariableType(lineText)

                        ws.Cells(row, 1).Value = vbComp.Name
                        ws.Cells(row, 2).Value = "TypeMember"
                        ws.Cells(row, 3).Value = blockName
                        ws.Cells(row, 4).Value = memberName
                        ws.Cells(row, 5).Value = memberType
                        ws.Cells(row, 7).Value = lineText
                        ws.Cells(row, 8).Value = i
                        row = row + 1
                    End If

                End If

            End If

        Next i

    Next vbComp

End Sub

Private Function IsConstDeclarationLine(ByVal lineText As String) As Boolean

    Dim t As String
    t = LCase$(Trim(lineText))

    IsConstDeclarationLine = _
        t Like "const *" Or _
        t Like "private const *" Or _
        t Like "public const *"

End Function

Private Function IsEnumStartLine(ByVal lineText As String) As Boolean

    Dim t As String
    t = LCase$(Trim(lineText))

    IsEnumStartLine = _
        t Like "enum *" Or _
        t Like "private enum *" Or _
        t Like "public enum *"

End Function

Private Function IsTypeStartLine(ByVal lineText As String) As Boolean

    Dim t As String
    t = LCase$(Trim(lineText))

    IsTypeStartLine = _
        t Like "type *" Or _
        t Like "private type *" Or _
        t Like "public type *"

End Function

Private Function GetConstName(ByVal lineText As String) As String

    Dim t As String
    Dim p As Long

    t = Replace(lineText, "Private ", "", , , vbTextCompare)
    t = Replace(t, "Public ", "", , , vbTextCompare)
    t = Replace(t, "Const ", "", , , vbTextCompare)

    p = InStr(1, t, " As ", vbTextCompare)
    If p > 0 Then t = Left$(t, p - 1)

    p = InStr(t, "=")
    If p > 0 Then t = Left$(t, p - 1)

    GetConstName = Trim(t)

End Function

Private Function GetBlockName( _
    ByVal lineText As String, _
    ByVal blockKeyword As String) As String

    Dim t As String

    t = Replace(lineText, "Private ", "", , , vbTextCompare)
    t = Replace(t, "Public ", "", , , vbTextCompare)
    t = Replace(t, blockKeyword & " ", "", , , vbTextCompare)

    GetBlockName = Trim(t)

End Function

Private Function GetEnumMemberName(ByVal lineText As String) As String

    Dim p As Long

    p = InStr(lineText, "=")

    If p > 0 Then
        GetEnumMemberName = Trim(Left$(lineText, p - 1))
    Else
        GetEnumMemberName = Trim(lineText)
    End If

End Function

Private Function GetEnumMemberValue(ByVal lineText As String) As String

    Dim p As Long

    p = InStr(lineText, "=")

    If p > 0 Then
        GetEnumMemberValue = Trim(Mid$(lineText, p + 1))
    Else
        GetEnumMemberValue = ""
    End If

End Function

Private Sub OutputNamingRuleCheck(ByVal vbProj As Object, ByVal wb As Workbook)

    Dim ws As Worksheet
    Dim vbComp As Object
    Dim codeMod As Object
    Dim i As Long
    Dim row As Long
    Dim lineText As String
    Dim procName As String
    Dim procKind As Long
    Dim checkedName As String
    Dim checkedType As String
    Dim message As String

    Set ws = PrepareOutputSheet(wb, "命名規則チェック")

    ws.Range("A1:F1").Value = Array("モジュール名", "対象区分", "名前", "チェック結果", "コード", "行番号")
    row = 2

    For Each vbComp In vbProj.VBComponents

        Set codeMod = vbComp.CodeModule

        For i = 1 To codeMod.CountOfLines

            lineText = Trim(codeMod.lines(i, 1))

            If lineText <> "" And Left$(lineText, 1) <> "'" Then

                ' プロシージャ名チェック
                procName = ""
                On Error Resume Next
                procName = codeMod.ProcOfLine(i, procKind)
                On Error GoTo 0

                If procName <> "" Then
                    If codeMod.ProcStartLine(procName, procKind) = i Then
                        message = CheckBasicNameRule(procName)

                        If message <> "" Then
                            ws.Cells(row, 1).Value = vbComp.Name
                            ws.Cells(row, 2).Value = "プロシージャ"
                            ws.Cells(row, 3).Value = procName
                            ws.Cells(row, 4).Value = message
                            ws.Cells(row, 5).Value = lineText
                            ws.Cells(row, 6).Value = i
                            row = row + 1
                        End If
                    End If
                End If

                ' 変数名チェック
                If IsVariableDeclarationLine(lineText) Then
                    checkedName = GetVariableName(lineText)
                    checkedType = GetVariableType(lineText)

                    message = CheckBasicNameRule(checkedName)

                    If LCase$(checkedType) = "boolean" Then
                        message = AppendCheckMessage(message, CheckBooleanNameRule(checkedName))
                    End If

                    If message <> "" Then
                        ws.Cells(row, 1).Value = vbComp.Name
                        ws.Cells(row, 2).Value = "変数"
                        ws.Cells(row, 3).Value = checkedName
                        ws.Cells(row, 4).Value = message
                        ws.Cells(row, 5).Value = lineText
                        ws.Cells(row, 6).Value = i
                        row = row + 1
                    End If
                End If

                ' 定数名チェック
                If IsConstDeclarationLine(lineText) Then
                    checkedName = GetConstName(lineText)
                    message = CheckConstNameRule(checkedName)

                    If message <> "" Then
                        ws.Cells(row, 1).Value = vbComp.Name
                        ws.Cells(row, 2).Value = "定数"
                        ws.Cells(row, 3).Value = checkedName
                        ws.Cells(row, 4).Value = message
                        ws.Cells(row, 5).Value = lineText
                        ws.Cells(row, 6).Value = i
                        row = row + 1
                    End If
                End If

                ' Enum名チェック
                If IsEnumStartLine(lineText) Then
                    checkedName = GetBlockName(lineText, "Enum")
                    message = CheckBasicNameRule(checkedName)

                    If message <> "" Then
                        ws.Cells(row, 1).Value = vbComp.Name
                        ws.Cells(row, 2).Value = "Enum"
                        ws.Cells(row, 3).Value = checkedName
                        ws.Cells(row, 4).Value = message
                        ws.Cells(row, 5).Value = lineText
                        ws.Cells(row, 6).Value = i
                        row = row + 1
                    End If
                End If

                ' Type名チェック
                If IsTypeStartLine(lineText) Then
                    checkedName = GetBlockName(lineText, "Type")
                    message = CheckBasicNameRule(checkedName)

                    If message <> "" Then
                        ws.Cells(row, 1).Value = vbComp.Name
                        ws.Cells(row, 2).Value = "Type"
                        ws.Cells(row, 3).Value = checkedName
                        ws.Cells(row, 4).Value = message
                        ws.Cells(row, 5).Value = lineText
                        ws.Cells(row, 6).Value = i
                        row = row + 1
                    End If
                End If

            End If
        Next
    Next
End Sub

Private Function CheckBasicNameRule(ByVal targetName As String) As String

    Dim result As String
    Dim firstChar As String

    targetName = Trim(targetName)

    If targetName = "" Then
        CheckBasicNameRule = "名前が取得できません"
        Exit Function
    End If

    firstChar = Left$(targetName, 1)

    If Not firstChar Like "[A-Za-z]" Then
        result = AppendCheckMessage(result, "先頭が英字ではありません")
    End If

    If InStr(targetName, " ") > 0 Then
        result = AppendCheckMessage(result, "名前に空白が含まれています")
    End If

    If InStr(targetName, "-") > 0 Then
        result = AppendCheckMessage(result, "名前にハイフンが含まれています")
    End If

    CheckBasicNameRule = result

End Function

Private Function CheckBooleanNameRule(ByVal targetName As String) As String

    Dim t As String
    t = LCase$(targetName)

    If Left$(t, 2) = "is" _
        Or Left$(t, 3) = "has" _
        Or Left$(t, 3) = "can" _
        Or Left$(t, 6) = "should" Then

        CheckBooleanNameRule = ""
    Else
        CheckBooleanNameRule = "Boolean変数は is/has/can/should で始めることを推奨"
    End If

End Function

Private Function CheckConstNameRule(ByVal targetName As String) As String

    Dim i As Long
    Dim ch As String
    Dim hasLower As Boolean

    targetName = Trim(targetName)

    If targetName = "" Then
        CheckConstNameRule = "名前が取得できません"
        Exit Function
    End If

    For i = 1 To Len(targetName)
        ch = Mid$(targetName, i, 1)

        If ch Like "[a-z]" Then
            hasLower = True
            Exit For
        End If
    Next i

    If hasLower Then
        CheckConstNameRule = "定数名は大文字スネークケースを推奨"
    ElseIf InStr(targetName, "_") = 0 Then
        CheckConstNameRule = "定数名は大文字スネークケースを推奨"
    Else
        CheckConstNameRule = ""
    End If

End Function

Private Function AppendCheckMessage( _
    ByVal currentMessage As String, _
    ByVal addMessage As String) As String

    If Trim(addMessage) = "" Then
        AppendCheckMessage = currentMessage
    ElseIf Trim(currentMessage) = "" Then
        AppendCheckMessage = addMessage
    Else
        AppendCheckMessage = currentMessage & " / " & addMessage
    End If

End Function

Private Sub BackupPreviousDesignSheet(ByVal wb As Workbook)

    Dim currentWs As Worksheet
    Dim backupWs As Worksheet

    On Error Resume Next
    Set currentWs = wb.Worksheets("詳細設計書")
    Set backupWs = wb.Worksheets("詳細設計書_前回")
    On Error GoTo 0

    If currentWs Is Nothing Then Exit Sub

    Application.DisplayAlerts = False
    If Not backupWs Is Nothing Then
        backupWs.Delete
    End If
    Application.DisplayAlerts = True

    currentWs.Copy After:=wb.Worksheets(wb.Worksheets.Count)
    Set backupWs = wb.Worksheets(wb.Worksheets.Count)
    backupWs.Name = "詳細設計書_前回"

End Sub

Private Sub OutputDiffReport(ByVal wb As Workbook)

    Dim wsCurrent As Worksheet
    Dim wsPrev As Worksheet
    Dim wsDiff As Worksheet
    Dim currentDict As Object
    Dim prevDict As Object
    Dim key As Variant
    Dim row As Long

    On Error Resume Next
    Set wsCurrent = wb.Worksheets("詳細設計書")
    Set wsPrev = wb.Worksheets("詳細設計書_前回")
    On Error GoTo 0

    Set wsDiff = PrepareOutputSheet(wb, "差分比較")

    wsDiff.Range("A1:F1").Value = Array("差分区分", "処理ID", "前回内容", "今回内容", "比較対象", "備考")
    row = 2

    If wsCurrent Is Nothing Or wsPrev Is Nothing Then
        wsDiff.Cells(row, 1).Value = "比較不可"
        wsDiff.Cells(row, 6).Value = "詳細設計書または詳細設計書_前回が存在しません"
        Exit Sub
    End If

    Set currentDict = BuildDesignSheetDictionary(wsCurrent)
    Set prevDict = BuildDesignSheetDictionary(wsPrev)

    ' 追加・変更
    For Each key In currentDict.Keys
        If Not prevDict.Exists(key) Then
            wsDiff.Cells(row, 1).Value = "追加"
            wsDiff.Cells(row, 2).Value = key
            wsDiff.Cells(row, 4).Value = currentDict(key)
            row = row + 1
        ElseIf currentDict(key) <> prevDict(key) Then
            wsDiff.Cells(row, 1).Value = "変更"
            wsDiff.Cells(row, 2).Value = key
            wsDiff.Cells(row, 3).Value = prevDict(key)
            wsDiff.Cells(row, 4).Value = currentDict(key)
            wsDiff.Cells(row, 5).Value = "詳細設計書行内容"
            row = row + 1
        End If
    Next key

    ' 削除
    For Each key In prevDict.Keys
        If Not currentDict.Exists(key) Then
            wsDiff.Cells(row, 1).Value = "削除"
            wsDiff.Cells(row, 2).Value = key
            wsDiff.Cells(row, 3).Value = prevDict(key)
            row = row + 1
        End If
    Next key

End Sub

Private Function BuildDesignSheetDictionary(ByVal ws As Worksheet) As Object

    Dim dict As Object
    Dim lastRow As Long
    Dim lastCol As Long
    Dim r As Long
    Dim c As Long
    Dim processId As String
    Dim rowText As String

    Set dict = CreateObject("Scripting.Dictionary")

    lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).row
    lastCol = ws.Cells(1, ws.Columns.Count).End(xlToLeft).Column

    For r = 2 To lastRow

        processId = CStr(ws.Cells(r, 1).Value)

        If processId <> "" Then

            rowText = ""

            For c = 1 To lastCol
                rowText = rowText & "[" & ws.Cells(1, c).Value & "=" & CStr(ws.Cells(r, c).Value) & "]"
            Next c

            If Not dict.Exists(processId) Then
                dict.Add processId, rowText
            End If

        End If

    Next r

    Set BuildDesignSheetDictionary = dict

End Function

Private Sub ExportDesignWorkbookToHtml(ByVal wb As Workbook)

    Dim htmlPath As String
    Dim tempPath As String
    Dim baseName As String
    Dim exportWb As Workbook

    If wb.Path = "" Then
        MsgBox "HTML出力するには、先にこのブックを保存してください。", vbExclamation
        Exit Sub
    End If

    baseName = Left$(wb.Name, InStrRev(wb.Name, ".") - 1)
    htmlPath = wb.Path & Application.PathSeparator & baseName & "_設計書.html"
    tempPath = wb.Path & Application.PathSeparator & baseName & "_設計書出力用.xlsx"

    wb.Worksheets.Copy
    Set exportWb = ActiveWorkbook

    Application.DisplayAlerts = False

    exportWb.SaveAs _
        Filename:=htmlPath, _
        FileFormat:=xlHtml

    exportWb.Close SaveChanges:=False

    Application.DisplayAlerts = True

    MsgBox "HTML設計書を出力しました。" & vbCrLf & htmlPath, vbInformation

End Sub

Private Sub ExportDesignWorkbookToCustomHtml(ByVal wb As Workbook)

    Dim htmlPath As String
    Dim baseName As String
    Dim html As String

    If wb.Path = "" Then
        MsgBox "HTML出力するには、先にこのブックを保存してください。", vbExclamation
        Exit Sub
    End If

    baseName = Left$(wb.Name, InStrRev(wb.Name, ".") - 1)
    htmlPath = wb.Path & Application.PathSeparator & baseName & "_独自設計書.html"

    html = BuildDesignHtml(wb, baseName)

    SaveTextAsUtf8 htmlPath, html

    MsgBox "独自HTML設計書を出力しました。" & vbCrLf & htmlPath, vbInformation

