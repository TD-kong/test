    css = css & ".hidden{display:none;}" & vbCrLf
    css = css & "</style>" & vbCrLf

    BuildDesignHtmlStyle = css

End Function

Private Function BuildDesignHtmlScript() As String

    Dim js As String

    js = ""
    js = js & "<script>" & vbCrLf
    js = js & "function filterRows(){" & vbCrLf
    js = js & "  var q=document.getElementById('searchBox').value.toLowerCase();" & vbCrLf
    js = js & "  var rows=document.querySelectorAll('tbody tr');" & vbCrLf
    js = js & "  rows.forEach(function(row){" & vbCrLf
    js = js & "    var hit=row.innerText.toLowerCase().indexOf(q)>=0;" & vbCrLf
    js = js & "    row.className=hit?'':'hidden';" & vbCrLf
    js = js & "  });" & vbCrLf
    js = js & "}" & vbCrLf
    js = js & "</script>" & vbCrLf

    BuildDesignHtmlScript = js

End Function

