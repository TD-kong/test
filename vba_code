Private Function IsFlowLine(ByVal lineText As String) As Boolean
    Dim t As String
    t = LCase$(Trim(lineText))

    IsFlowLine = _
        t Like "if * then*" Or _
        t Like "else*" Or _
        t Like "elseif *" Or _
        t Like "for *" Or _
        t Like "for each *" Or _
        t Like "do *" Or _
        t Like "loop*" Or _
        t Like "select case *" Or _
        t Like "case *" Or _
        t Like "call *" Or _
        InStr(t, " = ") > 0
End Function

Private Function IsFlowStartLine(ByVal lineText As String) As Boolean
    Dim t As String
    t = LCase$(Trim(lineText))

    IsFlowStartLine = _
        t Like "if * then*" Or _
        t Like "for *" Or _
        t Like "for each *" Or _
        t Like "do *" Or _
        t Like "select case *"
