Private Function IsFlowEndLine(ByVal lineText As String) As Boolean
    Dim t As String
    t = LCase$(Trim(lineText))

    IsFlowEndLine = _
        t = "end if" Or _
        t = "next" Or _
        Left$(t, 4) = "next" Or _
        Left$(t, 4) = "loop" Or _
        t = "end select"
End Function

Private Sub FormatDesignWorkbook(ByVal wb As Workbook)

    Dim ws As Worksheet
    Dim lastRow As Long
    Dim lastCol As Long

    For Each ws In wb.Worksheets

        If ws.Name = "概要" _
            Or ws.Name = "詳細設計書" _
            Or ws.Name = "変数一覧" _
            Or ws.Name = "呼び出し関係" _
            Or ws.Name = "シート入出力" _
            Or ws.Name = "画面項目" _
            Or ws.Name = "処理フロー" _
            Or ws.Name = "コード全文" _
            Or ws.Name = "コメント不足" _
            Or ws.Name = "未使用候補" _
            Or ws.Name = "定数_Enum_Type一覧" _
            Or ws.Name = "命名規則チェック" _
            Or ws.Name = "差分比較" Then

            lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).row
            lastCol = ws.Cells(1, ws.Columns.Count).End(xlToLeft).Column

            With ws.Range(ws.Cells(1, 1), ws.Cells(lastRow, lastCol))
                .Borders.LineStyle = xlContinuous
                .VerticalAlignment = xlTop
                .WrapText = True
            End With

            With ws.Rows(1)
                .Font.Bold = True
                .Interior.Color = RGB(220, 230, 241)
                .AutoFilter
            End With

            ws.Columns.AutoFit

            If ws.Columns(1).ColumnWidth > 25 Then ws.Columns(1).ColumnWidth = 25
            If lastCol >= 4 Then ws.Columns(4).ColumnWidth = 45
            If lastCol >= 5 Then ws.Columns(5).ColumnWidth = 60

        End If

    Next ws

