Private Function IsVariableDeclarationLine(ByVal lineText As String) As Boolean
    Dim t As String
    t = LCase$(Trim(lineText))

    IsVariableDeclarationLine = _
        t Like "dim *" Or _
        t Like "static *" Or _
        t Like "private *" Or _
        t Like "public *" Or _
        t Like "const *" Or _
        t Like "private const *" Or _
        t Like "public const *"
End Function

Private Function GetVariableScope(ByVal lineText As String) As String
    Dim t As String
    t = LCase$(Trim(lineText))

    If Left$(t, 7) = "private" Then
        GetVariableScope = "Private"
    ElseIf Left$(t, 6) = "public" Then
        GetVariableScope = "Public"
    ElseIf Left$(t, 6) = "static" Then
        GetVariableScope = "Static"
    ElseIf Left$(t, 5) = "const" Or InStr(t, " const ") > 0 Then
        GetVariableScope = "Const"
    Else
        GetVariableScope = "Local"
    End If
End Function

Private Function GetVariableName(ByVal lineText As String) As String
    Dim t As String
    Dim p As Long

    t = Replace(lineText, "Private ", "", , , vbTextCompare)
    t = Replace(t, "Public ", "", , , vbTextCompare)
    t = Replace(t, "Static ", "", , , vbTextCompare)
    t = Replace(t, "Dim ", "", , , vbTextCompare)
    t = Replace(t, "Const ", "", , , vbTextCompare)

    p = InStr(1, t, " As ", vbTextCompare)
    If p > 0 Then t = Left$(t, p - 1)

    p = InStr(t, "=")
    If p > 0 Then t = Left$(t, p - 1)

    GetVariableName = Trim(t)
End Function

Private Function GetVariableType(ByVal lineText As String) As String
    Dim p As Long
    Dim t As String

    p = InStr(1, lineText, " As ", vbTextCompare)

    If p > 0 Then
        t = Mid$(lineText, p + 4)
        If InStr(t, "=") > 0 Then t = Left$(t, InStr(t, "=") - 1)
        GetVariableType = Trim(t)
    Else
        GetVariableType = ""
    End If
End Function

Private Function GetVariableInitialValue(ByVal lineText As String) As String
    Dim p As Long

    p = InStr(lineText, "=")

    If p > 0 Then
        GetVariableInitialValue = Trim(Mid$(lineText, p + 1))
    Else
        GetVariableInitialValue = ""
    End If
End Function

