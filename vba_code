Private Sub SaveTextAsUtf8( _
    ByVal filePath As String, _
    ByVal text As String)

    Dim stream As Object

    Set stream = CreateObject("ADODB.Stream")

    With stream
        .Type = 2
        .Charset = "UTF-8"
        .Open
        .WriteText text
        .SaveToFile filePath, 2
        .Close
    End With

End Sub

Private Function BuildDesignHtml(ByVal wb As Workbook, ByVal title As String) As String

    Dim html As String
    Dim ws As Worksheet

    html = ""
    html = html & "<!doctype html>" & vbCrLf
    html = html & "<html lang=""ja"">" & vbCrLf
    html = html & "<head>" & vbCrLf
    html = html & "<meta charset=""UTF-8"">" & vbCrLf
    html = html & "<title>" & HtmlEncode(title) & " 詳細設計書</title>" & vbCrLf
    html = html & BuildDesignHtmlStyle()
    html = html & BuildDesignHtmlScript()
    html = html & "</head>" & vbCrLf
    html = html & "<body>" & vbCrLf

    html = html & "<aside class=""side"">" & vbCrLf
    html = html & "<h1>詳細設計書</h1>" & vbCrLf
    html = html & "<input id=""searchBox"" type=""search"" placeholder=""検索"" onkeyup=""filterRows()"">" & vbCrLf
    html = html & "<nav>" & vbCrLf

    For Each ws In wb.Worksheets
        If IsDesignOutputSheet(ws.Name) Then
            html = html & "<a href=""#" & HtmlId(ws.Name) & """>" & HtmlEncode(ws.Name) & "</a>" & vbCrLf
        End If
    Next ws

    html = html & "</nav>" & vbCrLf
    html = html & "</aside>" & vbCrLf

    html = html & "<main class=""main"">" & vbCrLf
    html = html & "<div class=""title"">" & vbCrLf
    html = html & "<div class=""book"">" & HtmlEncode(title) & "</div>" & vbCrLf
    html = html & "<div class=""date"">出力日時: " & Format(Now, "yyyy/mm/dd hh:nn:ss") & "</div>" & vbCrLf
    html = html & "</div>" & vbCrLf

    For Each ws In wb.Worksheets
        If IsDesignOutputSheet(ws.Name) Then
            html = html & BuildSheetHtml(ws)
        End If
    Next ws

    html = html & "</main>" & vbCrLf
    html = html & "</body>" & vbCrLf
    html = html & "</html>" & vbCrLf

    BuildDesignHtml = html

End Function

Private Function IsDesignOutputSheet(ByVal sheetName As String) As Boolean

    Select Case sheetName
        Case "概要", _
             "詳細設計書", _
             "変数一覧", _
             "呼び出し関係", _
             "シート入出力", _
             "画面項目", _
             "処理フロー", _
             "コード全文", _
             "コメント不足", _
             "未使用候補", _
             "定数_Enum_Type一覧", _
             "命名規則チェック", _
             "差分比較"

            IsDesignOutputSheet = True

        Case Else
            IsDesignOutputSheet = False
    End Select

End Function

Private Function BuildSheetHtml(ByVal ws As Worksheet) As String

    Dim html As String
    Dim lastRow As Long
    Dim lastCol As Long
    Dim r As Long
    Dim c As Long
    Dim cellText As String
    Dim isCodeColumn As Boolean

    lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).row
    lastCol = ws.Cells(1, ws.Columns.Count).End(xlToLeft).Column

    html = ""
    html = html & "<section id=""" & HtmlId(ws.Name) & """ class=""section"">" & vbCrLf
    html = html & "<h2>" & HtmlEncode(ws.Name) & "</h2>" & vbCrLf

    If lastRow < 1 Or lastCol < 1 Then
        html = html & "<p class=""empty"">データなし</p>" & vbCrLf
        html = html & "</section>" & vbCrLf
        BuildSheetHtml = html
        Exit Function
    End If

    html = html & "<div class=""tableWrap"">" & vbCrLf
    html = html & "<table>" & vbCrLf

    html = html & "<thead><tr>" & vbCrLf
    For c = 1 To lastCol
        html = html & "<th>" & HtmlEncode(CStr(ws.Cells(1, c).Value)) & "</th>" & vbCrLf
    Next c
    html = html & "</tr></thead>" & vbCrLf

    html = html & "<tbody>" & vbCrLf

    For r = 2 To lastRow
        html = html & "<tr>" & vbCrLf

        For c = 1 To lastCol

            cellText = CStr(ws.Cells(r, c).Value)
            isCodeColumn = IsCodeTextColumn(ws, c)

            If isCodeColumn Then
                html = html & "<td class=""codeCell""><pre>" & HtmlEncode(cellText) & "</pre></td>" & vbCrLf
            Else
                html = html & "<td>" & Replace(HtmlEncode(cellText), vbLf, "<br>") & "</td>" & vbCrLf
            End If

        Next c

        html = html & "</tr>" & vbCrLf
    Next r

    html = html & "</tbody>" & vbCrLf
    html = html & "</table>" & vbCrLf
    html = html & "</div>" & vbCrLf
    html = html & "</section>" & vbCrLf

    BuildSheetHtml = html

End Function

Private Function IsCodeTextColumn(ByVal ws As Worksheet, ByVal colNo As Long) As Boolean

    Dim headerText As String

    headerText = CStr(ws.Cells(1, colNo).Value)

    IsCodeTextColumn = _
        headerText = "コード全文" Or _
        headerText = "コード"

End Function

Private Function HtmlEncode(ByVal text As String) As String

    text = Replace(text, "&", "&amp;")
    text = Replace(text, "<", "&lt;")
    text = Replace(text, ">", "&gt;")
    text = Replace(text, """", "&quot;")
    text = Replace(text, "'", "&#39;")

    HtmlEncode = text

End Function

Private Function HtmlId(ByVal text As String) As String

    Dim i As Long
    Dim ch As String
    Dim result As String

    For i = 1 To Len(text)
        ch = Mid$(text, i, 1)

        If ch Like "[A-Za-z0-9]" Then
            result = result & ch
        Else
            result = result & "_"
        End If
    Next i

    HtmlId = "s_" & result

End Function

